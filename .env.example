# Register an app at developers.deriv.com and paste its numeric App ID here.
DERIV_APP_ID=

# Leave blank in paper mode. In demo mode, use a NEW restricted token.
# Never commit this value. Never use the token exposed in a screenshot/chat.
DERIV_TOKEN=

# paper = live Deriv data + simulated contracts
# demo  = actual contracts on a Deriv virtual account only
MODE=paper

# Optional explicit symbol. Leave blank to discover by display name.
SYMBOL=
TARGET_DISPLAY_NAME=Volatility 75 (1s)

CURRENCY=USD
STAKE=0.35
DURATION_TICKS=30
BAR_SECONDS=15

MAX_TRADES_PER_DAY=8
MAX_DAILY_LOSS=3.00
MAX_CONSECUTIVE_LOSSES=3
COOLDOWN_SECONDS=180
TEST_DAYS=7
TIMEZONE=Africa/Johannesburg

# Health endpoint for local/Render monitoring.
PORT=3000
